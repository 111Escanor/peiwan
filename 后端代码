from flask import Flask, jsonify, request
import pymysql

app = Flask(__name__)

# 数据库连接
def db():
    return pymysql.connect(
        host="localhost",
        user="root",
        password="123456",
        database="escanor",
        cursorclass=pymysql.cursors.DictCursor
    )

# 1. 获取所有陪玩师
@app.route('/api/masters', methods=['GET'])
def get_masters():
    conn = db()
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM master")
    data = cursor.fetchall()
    conn.close()
    return jsonify(data)
